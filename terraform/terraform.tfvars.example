# Terraform Variables Example
# Copy to terraform.tfvars and customize

aws_region    = "ap-southeast-1"
instance_type = "m6i.2xlarge"    # 8 vCPU, 32GB RAM (~$0.384/hr)
key_name      = "your-ssh-key"   # Your EC2 key pair name
spot_instance = false            # Set true for ~60% cost savings
volume_size   = 300              # GB (19 DBs + cluster topologies need more space)
volume_iops   = 3000             # gp3 IOPS

# Instance options:
# - m6i.xlarge:   4 vCPU, 16GB  (~$0.192/hr) - minimal, 2-3 DBs sequential
# - m6i.2xlarge:  8 vCPU, 32GB  (~$0.384/hr) - recommended (standalone benchmarks)
# - m6i.4xlarge: 16 vCPU, 64GB  (~$0.768/hr) - cluster topologies, parallel runs
# - r6i.2xlarge:  8 vCPU, 64GB  (~$0.504/hr) - memory-heavy (Milvus, Elasticsearch cluster)
